{
  "brand_name": "Dark",

  "colors": {
    "primary":      "#E2E8F0",
    "secondary":    "#63B3ED",
    "accent":       "#F6AD55",
    "background":   "#1A202C",
    "surface":      "#2D3748",
    "text_dark":    "#E2E8F0",
    "text_light":   "#F7FAFC",
    "text_muted":   "#A0AEC0",
    "success":      "#68D391",
    "warning":      "#F6AD55",
    "danger":       "#FC8181",
    "chart_palette": [
      "#63B3ED", "#F6AD55", "#68D391",
      "#FC8181", "#B794F4", "#76E4F7"
    ]
  },

  "fonts": {
    "heading":         "Calibri",
    "body":            "Calibri",
    "mono":            "Courier New",
    "heading_size":    36,
    "subheading_size": 24,
    "body_size":       18,
    "caption_size":    14
  },

  "slide": {
    "width_inches":  13.33,
    "height_inches": 7.5
  },

  "rules": {
    "accent_bar_height_inches": 0.08,
    "accent_bar_position":      "bottom",
    "logo_position":            "bottom_right",
    "max_bullets_per_slide":    6,
    "max_words_per_bullet":     15,
    "cover_background":         "background",
    "section_background":       "surface",
    "content_background":       "background",
    "use_slide_numbers":        true,
    "tone":                     "professional"
  },

  "layouts": {
    "cover":      { "title_y": 0.35, "subtitle_y": 0.55 },
    "section":    { "title_y": 0.35 },
    "content":    { "title_y": 0.05, "body_y": 0.20 },
    "two_column": { "title_y": 0.05, "body_y": 0.20, "split": 0.5 },
    "quote":      { "quote_y": 0.30, "attr_y": 0.65 },
    "closing":    { "title_y": 0.38, "subtitle_y": 0.55 }
  }
}